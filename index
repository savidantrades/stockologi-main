<div class="bottom-cta">
  <h2>Q2 slots are <em>limited by design.</em></h2>
  <p>One company per sector. Once your sector is filled, it is closed for the quarter.</p>
  <div class="bottom-capture">
    <div class="capture-label" style="text-align:left">Request Coverage Information</div>
    <div class="capture-form" id="bottomForm" style="display:flex;gap:0;border:1px solid var(--border-bright);border-radius:4px;overflow:hidden;">
      <input type="email" id="bottomEmail" placeholder="your@company.com" autocomplete="email" />
      <button onclick="handleSubmit('bottomEmail','bottomForm','bottomSuccess')">Request Info</button>
    </div>
    <div class="capture-success" id="bottomSuccess">
      <span>✓</span> We'll be in touch within 24 hours.
    </div>
    <p class="capture-note" style="text-align:left">For issuers only. Confidential.</p>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <span>© 2026 Stockologi</span>
  <span>Confidential — Authorized Recipients Only</span>
</footer>

<script>
  async function handleSubmit(inputId, formId, successId) {
    const email = document.getElementById(inputId).value.trim();
    if (!email || !email.includes('@')) {
      document.getElementById(inputId).style.outline = '1px solid #c9a84c';
      return;
    }
    const btn = document.querySelector('#' + formId + ' button');
    btn.textContent = 'Sending...';
    btn.disabled = true;

    try {
      await fetch('/functions/coverage-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
    } catch(e) { console.error(e); }

    document.getElementById(formId).style.display = 'none';
    document.getElementById(successId).style.display = 'flex';
  }
</script>
</body>
</html>
